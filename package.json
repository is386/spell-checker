{
  "name": "spell-checker",
  "version": "1.0.0",
  "description": "CLI for checking a document or given folder of documents of plain text for typos",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/is386/spell-checker.git"
  },
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "bun build src/index.ts --compile --outfile dist/spellchecker",
    "start": "node dist/index.js",
    "lint": "eslint --fix . && prettier --write .",
    "prepare": "husky"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "wordlist-english": "^1.2.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@eslint/json": "^1.0.1",
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^25.3.3",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "lint-staged": {
    "*.{js,mjs,cjs,ts}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  }
}
